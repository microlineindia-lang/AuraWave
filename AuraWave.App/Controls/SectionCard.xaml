<UserControl x:Class="AuraWave.App.Controls.SectionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AuraWave.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
     <Border Background="{StaticResource Brush.CardBackground}"
         BorderBrush="{StaticResource Brush.Border}"
         BorderThickness="1"
         CornerRadius="14"
         Padding="18"
         Margin="8">

     <Grid>

         <Grid.RowDefinitions>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="*"/>
         </Grid.RowDefinitions>

         <StackPanel Orientation="Horizontal"
                     Grid.Row="0"
                     Margin="0,0,0,12">

             <TextBlock Text="{Binding Title, ElementName=Root}"
                        Style="{StaticResource SectionTitleStyle}"/>

             <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                        Style="{StaticResource MutedTextStyle}"
                        Margin="10,2,0,0"/>

         </StackPanel>

         <ContentPresenter Grid.Row="1"
                           Content="{Binding Content, ElementName=Root}"/>

     </Grid>

 </Border>
    
</UserControl>
