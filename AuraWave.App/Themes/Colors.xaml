<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush.AppBackground" Color="#0B1220"/>
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="#0F172A"/>
    <SolidColorBrush x:Key="Brush.TopbarBackground" Color="#111827"/>
    <SolidColorBrush x:Key="Brush.PanelBackground" Color="#111827"/>
    <SolidColorBrush x:Key="Brush.CardBackground" Color="#1E293B"/>
    <SolidColorBrush x:Key="Brush.CardBackgroundAlt" Color="#172033"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#263449"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="Brush.Blue" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Brush.Green" Color="#22C55E"/>
    <SolidColorBrush x:Key="Brush.Orange" Color="#F59E0B"/>
    <SolidColorBrush x:Key="Brush.Red" Color="#EF4444"/>
    <SolidColorBrush x:Key="Brush.Cyan" Color="#06B6D4"/>
    <SolidColorBrush x:Key="Brush.Purple" Color="#8B5CF6"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#94A3B8"/>

</ResourceDictionary>
