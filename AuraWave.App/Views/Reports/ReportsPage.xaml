<Page x:Class="AuraWave.App.Views.Reports.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AuraWave.App.Views.Reports"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReportsPage">


    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel>

            <StackPanel>
                <TextBlock Text="Reports"
                       Style="{StaticResource PageTitleStyle}"/>

                <TextBlock Text="Generate PDF, Excel, CSV, Touchstone, and graph image exports"
                       Style="{StaticResource MutedTextStyle}"
                       Margin="0,6,0,0"/>
            </StackPanel>

            <Button DockPanel.Dock="Right"
                Content="Generate Report"
                Style="{StaticResource PrimaryButtonStyle}"
                VerticalAlignment="Center"/>

        </DockPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Report Options -->
            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="Export Options"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Select output format and report content"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,18"/>

                    <CheckBox Content="Test setup"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <CheckBox Content="Instrument configuration"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <CheckBox Content="Calibration information"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <CheckBox Content="2D polar plots"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <CheckBox Content="3D radiation pattern"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <CheckBox Content="Calculated parameters"
                          Foreground="{StaticResource Brush.TextPrimary}"
                          IsChecked="True"
                          Margin="0,6"/>

                    <Separator Margin="0,18"/>

                    <Button Content="Export PDF"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,10"/>

                    <Button Content="Export Excel"
                        Height="38"
                        Margin="0,0,0,10"/>

                    <Button Content="Export CSV"
                        Height="38"
                        Margin="0,0,0,10"/>

                    <Button Content="Export Graph Images"
                        Height="38"/>

                </StackPanel>

            </Border>

            <!-- Preview -->
            <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel>

                        <TextBlock Text="Report Preview"
                               Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="No report generated"
                               DockPanel.Dock="Right"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"/>

                    </DockPanel>

                    <Border Grid.Row="1"
                        Background="#F8FAFC"
                        CornerRadius="8"
                        Padding="30">

                        <StackPanel>

                            <TextBlock Text="AuraWave Antenna Radiation Pattern Report"
                                   Foreground="#111827"
                                   FontSize="26"
                                   FontWeight="Bold"/>

                            <TextBlock Text="Project: Untitled Measurement"
                                   Foreground="#334155"
                                   FontSize="15"
                                   Margin="0,12,0,0"/>

                            <TextBlock Text="Measurement Type: Radiation Pattern"
                                   Foreground="#334155"
                                   FontSize="15"/>

                            <TextBlock Text="Frequency: 2.400 GHz"
                                   Foreground="#334155"
                                   FontSize="15"/>

                            <Separator Margin="0,22"/>

                            <TextBlock Text="Graphs, calculated parameters, instrument settings, and calibration data will appear here."
                                   Foreground="#475569"
                                   FontSize="16"
                                   TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Page>

