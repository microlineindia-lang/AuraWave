<Page x:Class="AuraWave.App.Views.Settings.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AuraWave.App.Views.Settings"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">


    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings"
                   Style="{StaticResource PageTitleStyle}"/>

            <TextBlock Text="Appearance, hardware profiles, communication settings, database, logging, and user preferences"
                   Style="{StaticResource MutedTextStyle}"
                   Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="Categories"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,14"/>

                    <Button Content="Appearance"
                        Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="Hardware Profiles"
                        Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="Communication"
                        Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="Database"
                        Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="Logging"
                        Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="User Preferences"
                        Style="{StaticResource NavButtonStyle}"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="Application Settings"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="General configuration for AuraWave"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,24"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="54"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Theme"
                               VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                              SelectedIndex="0">
                            <ComboBoxItem Content="Dark Engineering"/>
                            <ComboBoxItem Content="Light Lab"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1"
                               Text="Default COM Port"
                               VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="COM3"/>

                        <TextBlock Grid.Row="2"
                               Text="VNA Interface"
                               VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              SelectedIndex="0">
                            <ComboBoxItem Content="Simulator"/>
                            <ComboBoxItem Content="VISA USB"/>
                            <ComboBoxItem Content="VISA TCP/IP"/>
                            <ComboBoxItem Content="Serial"/>
                        </ComboBox>

                        <TextBlock Grid.Row="3"
                               Text="Database"
                               VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Text="Local SQLite"/>

                        <TextBlock Grid.Row="4"
                               Text="Logging Level"
                               VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              SelectedIndex="1">
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Information"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                        </ComboBox>

                    </Grid>

                    <Button Content="Save Settings"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="160"
                        HorizontalAlignment="Left"
                        Margin="0,26,0,0"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Page>
