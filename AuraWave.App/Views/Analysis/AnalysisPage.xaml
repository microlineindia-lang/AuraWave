<Page x:Class="AuraWave.App.Views.Analysis.AnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AuraWave.App.Views.Analysis"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AnalysisPage">


    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Analysis"
                   Style="{StaticResource PageTitleStyle}"/>

            <TextBlock Text="Post-processing, beamwidth, sidelobe level, gain, VSWR, and comparison analysis"
                   Style="{StaticResource MutedTextStyle}"
                   Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="230"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}"
                Grid.RowSpan="2">

                <StackPanel>

                    <TextBlock Text="Measurement List"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Loaded scans"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,18"/>

                    <ListBox Background="#0F172A"
                         BorderBrush="{StaticResource Brush.Border}"
                         Foreground="{StaticResource Brush.TextPrimary}">
                        <ListBoxItem Content="No measurements loaded"/>
                    </ListBox>

                </StackPanel>

            </Border>

            <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <TextBlock Text="Main Analysis Graph"
                           Style="{StaticResource SectionTitleStyle}"
                           VerticalAlignment="Top"/>
                    <TextBlock Text="Normalized radiation pattern / comparison graph"
                           Foreground="{StaticResource Brush.TextMuted}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">
                <UniformGrid Columns="4">

                    <StackPanel>
                        <TextBlock Text="Peak Gain" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="-- dBi" FontSize="24" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="HPBW" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="-- °" FontSize="24" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="F/B Ratio" Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="-- dB" FontSize="24"
                    FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Side Lobe"
                               Style="{StaticResource MutedTextStyle}"/>
                        <TextBlock Text="-- dB"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    </StackPanel>
                </UniformGrid>
            </Border>
        </Grid>
    </Grid>

</Page>

