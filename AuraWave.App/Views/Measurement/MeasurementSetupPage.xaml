<Page x:Class="AuraWave.App.Views.Measurement.MeasurementSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AuraWave.App.Views.Measurement"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MeasurementSetupPage">


    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Measurement Setup"
                    Style="{StaticResource PageTitleStyle}"/>

            <TextBlock Text="Configure scan range, angle step, frequency sweep, E/H plane, and automation sequence"
                    Style="{StaticResource MutedTextStyle}"
                    Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="240"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="Scan Parameters"
                            Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Define angular and RF sweep settings"
                            Style="{StaticResource MutedTextStyle}"
                            Margin="0,4,0,18"/>

                    <TextBlock Text="Start Angle"/>
                    <TextBox Text="0" Margin="0,6,0,10"/>

                    <TextBlock Text="Stop Angle"/>
                    <TextBox Text="360" Margin="0,6,0,10"/>

                    <TextBlock Text="Step Size"/>
                    <TextBox Text="1" Margin="0,6,0,10"/>

                    <TextBlock Text="Frequency"/>
                    <TextBox Text="2.4 GHz" Margin="0,6,0,10"/>

                    <TextBlock Text="Plane"/>
                    <ComboBox SelectedIndex="0" Margin="0,6,0,18">
                        <ComboBoxItem Content="E-Plane"/>
                        <ComboBoxItem Content="H-Plane"/>
                        <ComboBoxItem Content="Dual Plane"/>
                    </ComboBox>

                    <Button Content="Validate Setup"
                         Style="{StaticResource PrimaryButtonStyle}"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="1"
                 Style="{StaticResource CardBorderStyle}">

                <Grid>
                    <TextBlock Text="Live Scan Preview"
                            Style="{StaticResource SectionTitleStyle}"
                            VerticalAlignment="Top"/>

                    <TextBlock Text="Polar scan path and expected measurement points will appear here"
                            Foreground="{StaticResource Brush.TextMuted}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Grid>

            </Border>

            <Border Grid.Row="1"
                 Grid.ColumnSpan="2"
                 Style="{StaticResource CardBorderStyle}">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Measurement Type"
                                Style="{StaticResource SectionTitleStyle}"/>
                        <RadioButton Content="Radiation Pattern" Margin="0,16,0,6" Foreground="{StaticResource Brush.TextPrimary}" IsChecked="True"/>
                        <RadioButton Content="Gain Measurement" Margin="0,6" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <RadioButton Content="S-Parameter Sweep" Margin="0,6" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Automation Sequence"
                                Style="{StaticResource SectionTitleStyle}"/>
                        <CheckBox Content="Auto home before scan" Margin="0,16,0,6" Foreground="{StaticResource Brush.TextPrimary}" IsChecked="True"/>
                        <CheckBox Content="Auto save CSV" Margin="0,6" Foreground="{StaticResource Brush.TextPrimary}" IsChecked="True"/>
                        <CheckBox Content="Generate report after scan" Margin="0,6" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Estimated Scan"
                                Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="361 points" FontSize="24" FontWeight="SemiBold" Margin="0,18,0,4"/>
                        <TextBlock Text="Approx. 6 minutes at 1 second dwell" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Page>
