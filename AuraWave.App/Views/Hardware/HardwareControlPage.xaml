<Page x:Class="AuraWave.App.Views.Hardware.HardwareControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AuraWave.App.Views.Hardware"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HardwareControlPage">

    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Hardware Control"
                   Style="{StaticResource PageTitleStyle}"/>

            <TextBlock Text="Manual control for turntable, VNA, RF switching, sensors, and communication"
                   Style="{StaticResource MutedTextStyle}"
                   Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Turntable -->
            <Border Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="Turntable Control"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Azimuth and positioner control"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,18"/>

                    <TextBlock Text="Target Angle"/>
                    <TextBox Text="90.00"
                         Margin="0,6,0,12"/>

                    <TextBlock Text="Speed"/>
                    <TextBox Text="10 deg/s"
                         Margin="0,6,0,12"/>

                    <UniformGrid Columns="2"
                             Margin="0,10,0,0">

                        <Button Content="Rotate Left"
                            Height="38"
                            Margin="0,0,6,8"/>

                        <Button Content="Rotate Right"
                            Height="38"
                            Margin="6,0,0,8"/>

                        <Button Content="Set Angle"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,6,8"/>

                        <Button Content="Return Home"
                            Height="38"
                            Margin="6,0,0,8"/>

                    </UniformGrid>

                    <Button Content="Emergency Stop"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="0,12,0,0"/>

                </StackPanel>

            </Border>

            <!-- Position Visualization -->
            <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">

                <Grid>
                    <TextBlock Text="Live Position Visualization"
                           Style="{StaticResource SectionTitleStyle}"
                           VerticalAlignment="Top"/>

                    <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">

                        <Ellipse Width="360"
                             Height="360"
                             Stroke="{StaticResource Brush.Border}"
                             StrokeThickness="2"/>

                        <Line X1="180"
                          Y1="180"
                          X2="180"
                          Y2="20"
                          Stroke="{StaticResource Brush.Blue}"
                          StrokeThickness="4"/>

                        <Ellipse Width="18"
                             Height="18"
                             Fill="{StaticResource Brush.Blue}"/>

                        <TextBlock Text="0.00°"
                               FontSize="32"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    </Grid>
                </Grid>

            </Border>

            <!-- VNA Control -->
            <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">

                <StackPanel>

                    <TextBlock Text="VNA Control"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBlock Text="Frequency sweep and trace configuration"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,18"/>

                    <TextBlock Text="Start Frequency"/>
                    <TextBox Text="1 GHz" Margin="0,6,0,10"/>

                    <TextBlock Text="Stop Frequency"/>
                    <TextBox Text="6 GHz" Margin="0,6,0,10"/>

                    <TextBlock Text="Sweep Points"/>
                    <TextBox Text="401" Margin="0,6,0,10"/>

                    <TextBlock Text="Power Level"/>
                    <TextBox Text="-10 dBm" Margin="0,6,0,14"/>

                    <Button Content="Connect VNA"
                        Style="{StaticResource PrimaryButtonStyle}"/>

                </StackPanel>

            </Border>

            <!-- Console -->
            <Border Grid.Row="1"
                Grid.Column="1"
                Style="{StaticResource CardBorderStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Communication Console"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <TextBox Grid.Row="1"
                         Text="[SCPI] Waiting for VNA connection&#x0a;[SERIAL] Motor controller simulator ready&#x0a;[RF] Switch state: E-Plane"
                         Background="#020617"
                         Foreground="{StaticResource Brush.TextSecondary}"
                         BorderBrush="{StaticResource Brush.Border}"
                         FontFamily="Consolas"
                         FontSize="13"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Page>


